# Vukixxx Server Configuration

# Port to listen on
PORT=3777

# AI Provider: "gemini" or "ollama"
AI_PROVIDER=gemini

# Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama URL (required if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

# Directory to save .md prompt files
PROMPTS_DIR=./prompts
